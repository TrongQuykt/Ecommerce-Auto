@model IEnumerable<StoreCars.Models.Oder>

@{
    ViewData["Title"] = "Index";

}
<div class="page-header">
    <h3 style="font-family:Helvetica;" class="page-title"> QUẢN LÝ ĐƠN HÀNG </h3>
    <nav aria-label="breadcrumb">

    </nav>
</div>
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <h4 style="font-family:Helvetica; text-align: center" class="card-title"> QUẢN LÝ ĐƠN ĐẶT HÀNG </h4>
        <div class="card-body">

            <table class="table">
                <thead>
                    <tr>
                        <th>
                            STT
                        </th>
                        <th>
                            Mã đơn hàng
                        </th>
                        <th>
                            Người đặt
                        </th>
                        <th>
                            SĐT
                        </th>
                        <th>
                            Tổng tiền
                        </th>

                        <th>
                            Ngày đặt
                        </th>

                        @* <th>
                            Địa chỉ giao hàng
                        </th> *@

                        <th>
                            Trạng thái
                        </th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int count = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @count
                            </td>
                            <td>
                                @item.OdersId
                            </td>
                            <td>
                                @item.Account?.FullName
                            </td>
@*                             <td>
                                @item.Account?.Email
                            </td> *@ 
                            <td>
                                @item.Account?.Phone
                            </td>
                            <td>
                                @item.Total?.ToString("C")
                            </td>

                            <td>
                                @item?.CreateDay
                            </td>
                          @*   <td>
                                @item?.Account?.Addresses.FirstOrDefault()?.Street ,
                                @item?.Account?.Addresses.FirstOrDefault()?.Ward,
                                @item?.Account?.Addresses.FirstOrDefault()?.District,
                                @item?.Account?.Addresses.FirstOrDefault()?.City
                            </td> *@
                            <td>Chờ xác nhận <i class="fas fa-clock"></i></td>
                            <td>
                                <a asp-action="ConfimOrder" asp-route-id="@item?.OdersId" class="btn btn-success mb-2"> Xác nhận đơn hàng</a><br />
                                <a asp-action="CanOrderby" asp-route-id="@item?.OdersId" class="btn btn-danger mb-2"> Hủy đơn hàng</a><br />
                                <a asp-action="OrderDetails" asp-route-id="@item?.OdersId" class="btn btn-info mb-2">Xem chi tiết</a>
                            </td>
                        </tr>
                        count++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>