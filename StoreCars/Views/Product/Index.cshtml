        <div style="text-align:center; margin-bottom: 30px">
            <h1>Danh Sách Sản Phẩm </h1>
        </div>
        <div class="tab-content">
            <div id="tab-1" class="tab-pane fade show p-0 active">
                <div class="row g-2">
                    @foreach (var item in Model)
                    {
                        <div class="col-lg-3 col-md-4 col-sm-6 wow fadeInUp" data-wow-delay="0.1s">
                            <div class="product-item rent-item mb-4">
                                <div class="position-relative bg-light overflow-hidden">
                                    <a asp-action="Details" asp-controller="Product" asp-route-id="@item.ProductId">
                                        <img class="img-fluid w-100" src="@Url.Content("~/contents/Images/Product/" + item.Image)" style="width:300px;height:270px;" alt="Ảnh xe">
                                    </a>
                                    <div class="bg-secondary rounded text-white position-absolute start-0 top-0 m-4 py-1 px-3">HOT</div>
                                </div>
                                <div class="text-center p-4">
                                    <a class="d-block h5 mb-2" asp-action="Details" asp-controller="Product" asp-route-id="@item.ProductId">@item.Name</a>
                                    <div class="d-flex justify-content-center mb-4">
                                        <div class="px-2">
                                            <i class="fa fa-car text-primary mr-1"></i>
                                            <span>2023</span>
                                        </div>
                                        <div class="px-2 border-left border-right">
                                            <i class="fa fa-cogs text-primary mr-1"></i>
                                            <span>AUTO</span>
                                        </div>
                                        <div class="px-2">
                                            <i class="fa fa-road text-primary mr-1"></i>
                                            <span>120Km/h</span>
                                        </div>
                                    </div>
                                    <span class="text-primary me-1"> @string.Format("{0:N0}", @item.Price) VNĐ</span>
                                    <span class="text-body text-decoration-line-through">@string.Format("{0:N0}", @item.Price + 900000) VNĐ</span>
                                </div>
                                <div class="d-flex border-top">
                                    @if ( item.ProductInventory?.QuantitySold >= item.ProductInventory?.Quantity )
                                    {
                                        <small class="w-100 text-center border-end py-2">
                                            <a class="text-body"  ><i class="fa fa-shopping-cart text-primary me-2"></i>Hết hàng</a>
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="w-50 text-center border-end py-2">
                                            <a class="text-body" asp-action="BuyNow" asp-controller="Order" asp-route-id="@item.ProductId"><i class="fa fa-shopping-cart text-primary me-2" style="padding: 10px 20px; background: #333"></i>Mua ngay</a>
                                        </small>
                                        <small class="w-50 text-center py-2">
                                            <a class="text-body" href="@Url.Action("AddToCart", "Order", new{ id=item.ProductId, strURL=Context.Request.Path})"><i class="fa fa-shopping-bag text-primary me-2" style="padding: 10px 20px; background: #333"></i>Thêm giỏ hàng</a>
                                        </small>
                                    }
                                </div>
                            </div>
                        </div>
                    }  
@*                     <div class="col-12 text-center wow fadeInUp" data-wow-delay="0.1s">
                        <a class="btn btn-primary rounded-pill py-3 px-5" href="">Xem thêm</a>
                    </div> *@
                </div>
            </div>
        </div>
</div>
<style>
    /* Add some styles to improve the look */
    .product-item {
        transition: transform .2s; /* Animation */
    }

        .product-item:hover {
            transform: scale(1.05); /* Zoom effect on hover */
        }

    .new-arrival-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: #ff6666;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 0.9em;
    }

    .product-img {
        height: 200px; /* Fixed height for images */
    }

    .product-name {
        min-height: 50px; /* Ensure uniform name container height */
    }

    .buy-now, .add-to-cart {
        display: block;
        width: 100%;
        text-align: center;
    }

    .buy-now {
        background-color: #0d6efd; /* Bootstrap primary color */
        color: white;
    }

    .add-to-cart {
        background-color: #6c757d; /* Bootstrap secondary color */
        color: white;
    }

    .product-price {
        font-weight: bold;
    }
</style>
<!-- Product End -->
<script>
    function navigateToSanPham(id) {
        window.location.href = '/Product/TypeList/' + id; // Thay đổi đường dẫn theo đúng route của bạn
    }
</script>
