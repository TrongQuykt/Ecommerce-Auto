@model Account
@{
	ViewData["Title"] = "Edit Profile";
	var AvartarClaim = User.Claims.FirstOrDefault(c => c.Type == "Avartar");
	var Avartar = "";
	if (AvartarClaim != null)
	{ Avartar = AvartarClaim.Value; }
}

<style>
	body {
		background: #f7f7ff;
		margin-top: 20px;
	}

	.card {
		position: relative;
		display: flex;
		flex-direction: column;
		min-width: 0;
		word-wrap: break-word;
		background-color: #fff;
		background-clip: border-box;
		border: 0 solid transparent;
		border-radius: .25rem;
		margin-bottom: 1.5rem;
		box-shadow: 0 2px 6px 0 rgb(218 218 253 / 65%), 0 2px 6px 0 rgb(206 206 238 / 54%);
	}

	.me-2 {
		margin-right: .5rem !important;
	}
</style>


<div class="container">
	<div class="main-body" style="margin-top: 150px;">
		<div class="container-fluid mb-5 wow fadeIn" data-wow-delay="0.1s" style="padding: 35px;">
			<div class="container">
				<div class="row g-2">
					<h1 style="text-align:center">
						Sửa thông tin cá nhân
					</h1>
				</div>
			</div>
		</div>
		<div class="row">
			<div class="col-lg-4">
				<div class="card">
					<div class="card-body">
						<div class="d-flex flex-column align-items-center text-center">
							<img src="@Avartar" alt="Admin" width="200">
							<div class="mt-3">
								<h4>@Model.FullName</h4>
								@*  <p class="text-secondary mb-1">Full Stack Developer</p>
								<p class="text-muted font-size-sm">Bay Area, San Francisco, CA</p>
								<button class="btn btn-primary">Follow</button>
								<button class="btn btn-outline-primary">Message</button> *@
							</div>
						</div>
						<hr class="my-4">
					</div>
				</div>
			</div>
			<div class="col-lg-8">
				<div class="card">
					<form asp-action="EditProfile" method="post" enctype="multipart/form-data">

						<input type="hidden" asp-for="AccountId" />	<input type="hidden" asp-for="UserName" />
					<div class="card-body" style="">
							<div class="row mb-3">
								<img src="@Url.Content("~/contents/Images/User/" + @Model.Avartar)" style="width: 200px; height: 200px; border-radius: 20px;" alt="" id="output">
								<label asp-for="Avartar" class="control-label"></label>
								<input type="file" name="fAvatar" asp-for="Avartar" class="form-control-file" onchange="loadFile(event)" />
								<span asp-validation-for="Avartar" class="text-danger"></span>
							</div>
						<div class="row mb-3">
							<div class="col-sm-3">
								<h6 class="mb-0">Họ tên</h6>
							</div>
							<div class="col-sm-9 text-secondary">
									<input type="text" class="form-control" asp-for="FullName" required>
							</div>
						</div>
						<div class="row mb-3">
							<div class="col-sm-3">
								<h6 class="mb-0">Email</h6>
							</div>
							<div class="col-sm-9 text-secondary">
									<input type="email" class="form-control" asp-for="Email" required>
							</div>
						</div>
						<div class="row mb-3">
							<div class="col-sm-3">
								<h6 class="mb-0">SDT</h6>
							</div>
							<div class="col-sm-9 text-secondary">
									<input type="number" class="form-control" asp-for="Phone">
							</div>
						</div>
						<div class="row mb-3">
							<div class="col-sm-3">
								<h6 class="mb-0">Ngày sinh</h6>
							</div>
							<div class="col-sm-9 text-secondary">
									<input type="datetime-local" class="form-control" asp-for="Birthday" required>
							</div>
						</div>	
					
						<div class="row mb-3">
							<div class="col-sm-3">
								<h6 class="mb-0">Giới tính</h6>
							</div>
							<div class="col-sm-9 text-secondary">
									<select class="form-control" asp-for="Gender" placeholder="" required>
										<option value="1" selected>Nam</option>
										<option value="2">Nữ</option>
										<option value="3">Khác</option>

									</select>
							</div>
						</div>
						<div class="row">
							<div class="col-sm-3"></div>
							<div class="col-sm-9 text-secondary">
								<input type="submit" class="btn btn-primary px-4" value="Sửa">
							</div>
						</div>
					</div>
					</form>
				</div>
				
			</div>
		</div>
	</div>
</div>
@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
	<script>
		var loadFile = function (event) {
			var image = document.getElementById("output");
			image.src = URL.createObjectURL(event.target.files[0]);
		};
	</script>
}
