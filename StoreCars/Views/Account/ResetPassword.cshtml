@{
    Layout = null;
    ViewData["Title"] = "Reset Password";

}
<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>ForgotPassword</title>
    <!-- plugins:css -->
    <link rel="stylesheet" href="~/LayoutAdmin/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/LayoutAdmin/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/LayoutAdmin/assets/css/style.css">
    <!-- End layout styles -->
    <link rel="shortcut icon" href="/images/istockphoto-693203680-612x612.png" />
</head>
<body>
    <div class="container-scroller">
        <div class="container-fluid page-body-wrapper full-page-wrapper">
            <div class="content-wrapper d-flex align-items-center auth">
                <div class="row flex-grow">
                    <div class="col-lg-4 mx-auto">
                        <div class="auth-form-light text-left p-5 d-flex justify-content-center align-items-center flex-column vh-70" style="border: 3px solid #000; border-radius: 10px;">
                             <div class="brand-logo">
                                <img src="/images/istockphoto-693203680-612x612.png">
                                <img src="/images/istockphoto-693203680-612x612 (1).png">
                            </div>
                            <h4>Đặt lại mật khẩu</h4>
                            <h6 class="font-weight-light">Nhập token xác thực</h6>
                            <form class="pt-3" method="post" asp-action="ResetPassword">
                                <div class="form-group">
                                    <input class="form-control form-control-lg" name="token" placeholder="Token" required style="border: 2px solid #000; border-radius: 8px">
                                </div>  
                                <div class="form-group">
                                    <input class="form-control form-control-lg" name="pass" placeholder="Mật khẩu mới" required style="border: 2px solid #000; border-radius: 8px">
                                </div>  
                                <div class="form-group">
                                    <input class="form-control form-control-lg" name="newpass" placeholder="Xác nhận mật khẩu" required style="border: 2px solid #000; border-radius: 8px">
                                </div>

                                <div class="mt-3 d-flex justify-content-center">
                                    <button style="background: #00FF33; align-items: center; justify-content: center" type="submit" class="btn btn-lg font-weight-medium auth-form-btn">Đặt lại mật khẩu</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <!-- content-wrapper ends -->
        </div>
        <!-- page-body-wrapper ends -->
    </div>
    <!-- container-scroller -->
    <!-- plugins:js -->
    <script src="~/LayoutAdmin/assets/vendors/js/vendor.bundle.base.js"></script>
    <!-- endinject -->
    <!-- Plugin js for this page -->
    <!-- End plugin js for this page -->
    <!-- inject:js -->
    <script src="~/LayoutAdmin/assets/js/off-canvas.js"></script>
    <script src="~/LayoutAdmin/assets/js/hoverable-collapse.js"></script>
    <script src="~/LayoutAdmin/assets/js/misc.js"></script>
    <!-- endinject -->  @await Component.InvokeAsync("Notyf");
</body>
</html>