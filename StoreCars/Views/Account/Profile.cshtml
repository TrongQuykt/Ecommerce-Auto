@model Account
@{
    var AvartarClaim = User.Claims.FirstOrDefault(c => c.Type == "Avartar");
    var Avartar = "";
    if (AvartarClaim != null)
    { Avartar = AvartarClaim.Value; }
    var Addresses = ViewBag.Addresses;
    ViewData["Title"] = "Profile";
    var DonHang = ViewBag.Donhang as List<Oder>;
}

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<style>
    body {
        margin-top: 20px;
        color: #1a202c;
        text-align: left;
        background-color: #e2e8f0;
    }

    .main-body {
        padding: 15px;
        margin-top: 150px;
    }

    .card {
        box-shadow: 0 1px 3px 0 rgba(0,0,0,.1), 0 1px 2px 0 rgba(0,0,0,.06);
    }

    .card {
        position: relative;
        display: flex;
        flex-direction: column;
        min-width: 0;
        word-wrap: break-word;
        background-color: #fff;
        background-clip: border-box;
        border: 0 solid rgba(0,0,0,.125);
        border-radius: .25rem;
    }

    .card-body {
        flex: 1 1 auto;
        min-height: 1px;
        padding: 1rem;
    }

    .gutters-sm {
        margin-right: -8px;
        margin-left: -8px;
    }

        .gutters-sm > .col, .gutters-sm > [class*=col-] {
            padding-right: 8px;
            padding-left: 8px;
        }

    .mb-3, .my-3 {
        margin-bottom: 1rem !important;
    }

    .bg-gray-300 {
        background-color: #e2e8f0;
    }

    .h-100 {
        height: 100% !important;
    }

    .shadow-none {
        box-shadow: none !important;
    }

    .card {
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .card-body {
        padding: 20px;
    }

    .row {
        margin-bottom: 10px;
    }

    .col-sm-1,
    .col-sm-2,
    .col-sm-2,
    .col-sm-1,
    .col-sm-2,
    .col-sm-2,
    .col-sm-2 {
        border-right: 1px solid #eee;
    }

        .col-sm-1:last-child,
        .col-sm-2:last-child,
        .col-sm-2:last-child,
        .col-sm-1:last-child,
        .col-sm-2:last-child,
        .col-sm-2:last-child,
        .col-sm-2:last-child {
            border-right: none;
        }

    h3 {
        color: #333;
    }

    h5 {
        font-family: 'Muli', sans-serif;
        margin-bottom: 5px;
    }

    hr {
        border-top: 1px solid #eee;
        margin-top: 15px;
        margin-bottom: 15px;
    }
</style>
<div class="container">
    <div class="main-body">

        <!-- Breadcrumb -->
        <div class="container-fluid bg-primary mb-5 wow fadeIn" data-wow-delay="0.1s" style="padding: 35px; background-color:white !important">
            <div class="container">
                <div class="row g-2">
                    <h1 style="text-align:center">
                        Trang cá nhân
                    </h1>
                </div>
            </div>
        </div>
        <!-- /Breadcrumb -->

        <div class="row gutters-sm">
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex flex-column align-items-center text-center">
                            @* <img @Url.Content("~/contents/Images/User/" + @Model.Avartar)  class="rounded-circle" width="250"> *@
                            @if (!string.IsNullOrEmpty(ViewBag.AvatarPath))
                            {
                                <img src="@ViewBag.AvatarPath" alt="Avatar"  style="width=350px; height: 350px">
                            }
                            <div class="mt-3">
                                <h4>@Model.FullName</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-8" style="border: 2px solid #000; border-radius: 10px">
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row">
                            <h4 style="text-align:center">Thông tin cá nhân</h4>
                            <hr />
                            <div class="col-sm-3">
                                <h6 class="mb-0">Họ tên:</h6>
                            </div>
                            <div class="col-sm-9 text-secondary">
                                @Model.FullName
                            </div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-sm-3">
                                <h6 class="mb-0">Email:</h6>
                            </div>
                            <div class="col-sm-9 text-secondary">
                                @Model.Email
                            </div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-sm-3">
                                <h6 class="mb-0">Phone:</h6>
                            </div>
                            <div class="col-sm-9 text-secondary">
                                @Model.Phone
                            </div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-sm-12 text-end">
                                <a class="btn rounded-pill py-sm-3 px-sm-5 ms-3" asp-action="EditProfile" style="background: #FFFF00">Sửa thông tin</a>
                            </div>
                        </div>
                        <hr>
                        <h4 style="text-align:center">Danh sách địa chỉ</h4>
                        <hr />
                        @foreach (var item in Addresses)
                        {
                            <div class="row">
                                <div class="col-sm-3">
                                    <h6 class="mb-0">Địa chỉ: </h6>
                                </div>
                                <div class="col-sm-6 text-secondary">
                                    @item.Street
                                    @item.Ward
                                    @item.District
                                    @item.City
                                    @item.Country
                                </div>
                                <div class="col-sm-3">

                                    <button onclick="getaddres(@item.AddressId)" class="action-icon"
                                            style="border:none; outline:none;">
                                        <i class="fas fa-edit"
                                           style="color:#ffd83b;font-size:25px;"></i>
                                    </button>
                                    <button onclick="getaddres1(@item.AddressId)" class="action-icon"
                                            style="border:none; outline:none;">
                                        <i class="fas fa-trash"
                                           style="color:#e75555;font-size:25px;"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-12 text-end">
                                    <a class="btn btn-primary rounded-pill py-sm-3 px-sm-5" data-toggle="modal" data-target="#myModal">Thêm địa chỉ</a>
                                </div>
                            </div>
                            <hr>
                        }
                    </div>
                </div>
            </div>
