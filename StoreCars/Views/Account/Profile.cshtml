</div>
<style>
    .custom-form {
        max-width: 400px;
        margin: 0 auto;
    }

    .custom-input {
        border-radius: 25px;
        padding: 12px 20px;
    }

    .custom-hr {
        border-color: #ddd;
    }

    .custom-btn {
        border-radius: 25px;
        padding: 10px 20px;
        margin-right: 10px;
    }

    .modal-footer {
        border-top: none;
    }

</style>
<!-- The Modal -->
<div class="modal" id="myModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" class="custom-form">
                <!-- Modal Header -->
                <div class="modal-header">
                    <h4 class="modal-title" style="text-align: center">Thêm địa chỉ</h4>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>

                <!-- Modal body -->
                <div class="modal-body">
                    <div class="form-group">
                        <input class="form-control form-control-lg custom-input" name="street" placeholder="Tên đường" required>
                    </div>
                    <hr class="custom-hr" />
                    <div class="form-group">
                        <input class="form-control form-control-lg custom-input" name="ward" placeholder="Phường" required>
                    </div>
                    <hr class="custom-hr" />
                    <div class="form-group">
                        <input class="form-control form-control-lg custom-input" name="district" placeholder="Quận" required>
                    </div>
                    <hr class="custom-hr" />
                    <div class="form-group">
                        <input class="form-control form-control-lg custom-input" name="city" placeholder="Thành phố" required>
                    </div>
                    <hr class="custom-hr" />
                    <div class="form-group">
                        <input class="form-control form-control-lg custom-input" name="country" placeholder="Quốc gia">
                    </div>
                </div>

                <!-- Modal footer -->
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary custom-btn">Thêm</button>
                    <button type="button" class="btn btn-danger custom-btn" data-dismiss="modal">Đóng</button>
                </div>
            </form>

        </div>
    </div>
</div>

<div class="modal" id="myModalEdit">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Edit">
                <!-- Modal Header -->
                <div class="modal-header">
                    <h4 class="modal-title">Thêm địa chỉ</h4>
                    <button onclick="closeModal()" class="close" data-dismiss="modal">&times;</button>
                </div>

                <!-- Modal body -->
                <div class="modal-body">
                    <input type="hidden" name="addresid" id="addresid" />
                    <div class="form-group">
                        <input class="form-control form-control-lg" name="streest" id="streest" placeholder="Tên đường" required>
                    </div>
                    <hr />
                    <div class="form-group">
                        <input class="form-control form-control-lg" name="ward" id="ward" placeholder="Phường" required>
                    </div>
                    <hr />
                    <div class="form-group">
                        <input class="form-control form-control-lg" name="distrist" id="distrist" placeholder="Quận" required>
                    </div>
                    <hr />
                    <div class="form-group">
                        <input class="form-control form-control-lg" name="city" id="city" placeholder="Thành phố" required>
                    </div>
                    <hr />
                    <div class="form-group">
                        <input class="form-control form-control-lg" name="contry" id="contry" placeholder="Quốc gia">
                    </div>
                </div>

                <!-- Modal footer -->
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Cập nhập</button>
                    <button type="button" class="btn btn-danger" onclick="closeModal()">Đóng</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal" id="myModalDelete">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="DeleteAd" method="post">
                <!-- Modal Header -->
                <div class="modal-header">
                    <h4 class="modal-title">Thêm địa chỉ</h4>
                    <button onclick="closeModalDelete()" class="close" data-dismiss="modal">&times;</button>
                </div>

                <!-- Modal body -->
                <div class="modal-body">
                    <input type="hidden" name="addid" id="addid" />
                    <h2>Bạn có chắc muốn xóa địa chỉ</h2>
                    <h3 id="diachi"></h3>
                </div>

                <!-- Modal footer -->
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Xóa</button>
                    <button type="button" class="btn btn-danger" onclick="closeModalDelete()">Đóng</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    function getaddres(id) {
        $('#myModalEdit').modal('show');
        $.ajax({
            url: '/Account/Edit',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                $('#addresid').val(data.addressId);
                $('#streest').val(data.street);
                $('#ward').val(data.ward);
                $('#distrist').val(data.district);
                $('#city').val(data.city);
                $('#contry').val(data.country);

            },
            error: function (xhr, status, error) {
                // Xử lý lỗi
                console.log(error); // In lỗi ra console (có thể thay đổi theo nhu cầu)
            }
        });
    };


    function closeModal() {
        $('#myModalEdit').modal('hide');
    };
    function getaddres1(id) {
        $('#myModalDelete').modal('show');
        $.ajax({
            url: '/Account/Edit',
            type: 'GET',
            data: { id: id },
            success: function (data) {
                $('#addid').val(data.addressId);
                $('#diachi').text(data.street + ',' + data.ward + ',' + data.district + ',' + data.city + ',' + data.country);


            },
            error: function (xhr, status, error) {
                // Xử lý lỗi
                console.log(error); // In lỗi ra console (có thể thay đổi theo nhu cầu)
            }
        });
    };
    function closeModalDelete() {
        $('#myModalDelete').modal('hide');
    };
</script>
